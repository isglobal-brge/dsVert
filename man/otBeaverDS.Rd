% Generated by hand; keep in sync with R/otBeaverDS.R
\name{otBeaverDS}
\alias{k2OtBeaverSampleDS}
\alias{k2OtMulSenderSetupDS}
\alias{k2OtMulReceiverChoicesDS}
\alias{k2OtMulSenderEncryptDS}
\alias{k2OtMulReceiverDecryptDS}
\alias{k2OtBeaverFinalizeDS}
\title{Direct OT-Beaver preprocessing methods}
\usage{
k2OtBeaverSampleDS(kind = "vecmul", n, p = 0L, ring = 63L,
  beaver_key = "k2_ot_beaver", session_id = NULL)

k2OtMulSenderSetupDS(ot_key, session_id = NULL)

k2OtMulReceiverChoicesDS(public_setup, y_key, ot_key, n, ring = 63L,
  points_blob_key = NULL, session_id = NULL)

k2OtMulSenderEncryptDS(points = NULL, points_blob_key = NULL, x_key, ot_key,
  output_key, n, ring = 63L, ciphertexts_blob_key = NULL,
  session_id = NULL)

k2OtMulReceiverDecryptDS(ciphertexts = NULL, ciphertexts_blob_key = NULL,
  ot_key, output_key, n, ring = 63L, session_id = NULL)

k2OtBeaverFinalizeDS(beaver_key = "k2_ot_beaver",
  target = c("vecmul", "grad", "spline_and", "spline_had1",
    "spline_had2"),
  cross_send_key = .otb_key(beaver_key, "cross_send"),
  cross_receive_key = .otb_key(beaver_key, "cross_receive"),
  session_id = NULL)
}
\arguments{
\item{kind}{Triple shape, either \code{"vecmul"} or \code{"matvec"}.}
\item{n}{Number of rows or vector elements.}
\item{p}{Number of columns for \code{"matvec"} triples.}
\item{ring}{Integer ring width, \code{63} or \code{127}.}
\item{beaver_key, ot_key}{Session-local key prefixes for sampled operands
and OT transcript state.}
\item{session_id}{Active MPC session identifier.}
\item{public_setup}{Base64url public sender setup relayed to the receiver.}
\item{y_key, x_key}{Session keys containing the receiver and sender
operands.}
\item{points, ciphertexts}{Base64url OT payloads relayed by the client.}
\item{points_blob_key, ciphertexts_blob_key}{Optional server-side blob keys
for relayed OT payloads.}
\item{output_key}{Session key where a cross-term share is stored.}
\item{target}{Existing online-Beaver slot to populate.}
\item{cross_send_key, cross_receive_key}{Session keys containing the two
cross-term shares produced by the bidirectional OT calls.}
}
\value{
Small metadata lists. Sampled operands, OT secrets and Beaver triple shares
remain in the server-side session.
}
\description{
Low-level DataSHIELD aggregate methods used by \pkg{dsVertClient} to build
Beaver triples without exposing the full triple to a trusted dealer. The client
relays only public OT messages between the two participating servers. After
finalisation, the resulting shares are installed into the same session slots
consumed by the existing online Beaver multiplication rounds.
}
\details{
This is a direct Chou-Orlandi OT correctness backend. It is suitable for
bounded validations and small jobs. Full production workloads use the
established server-side dealer preprocessing path by default until an
OT-extension backend is introduced.
}
\keyword{internal}
